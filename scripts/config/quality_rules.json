{
  "format_checks": [
    {
      "rule": "no_raw_urls",
      "description": "본문 내 원시 URL(http...) 노출 금지",
      "pattern": "(?<!\\()(?<!\\[)(?<!\\\")(?<!')(https?://\\S+)(?!\\))(?!\\])(?!\\\")(?!')",
      "severity": "error",
      "auto_fix": true
    },
    {
      "rule": "heading_must_have_link",
      "description": "### 소제목에 URL이 있으면 반드시 [제목](URL) 형식",
      "pattern": "^###\\s+[^\\[\\n]+\\(https?://",
      "severity": "error",
      "auto_fix": true
    },
    {
      "rule": "no_h1_heading",
      "description": "본문에 H1(# 제목) 사용 금지",
      "pattern": "^#\\s+[^#]",
      "severity": "error",
      "auto_fix": true
    },
    {
      "rule": "empty_line_after_heading",
      "description": "### 소제목 바로 다음 줄은 빈 줄이어야 함",
      "pattern": "^###.*\\n[^\\n]",
      "severity": "warning",
      "auto_fix": true
    }
  ],
  "content_checks": [
    {
      "rule": "min_char_count",
      "description": "본문 최소 2000자 이상 (SEO 1000단어 기준)",
      "min": 2000
    },
    {
      "rule": "min_word_count",
      "description": "본문 최소 1000단어 이상",
      "min": 1000
    },
    {
      "rule": "has_source_links",
      "description": "최소 1개 이상의 출처 링크 포함",
      "min_links": 1
    },
    {
      "rule": "has_references_section",
      "description": "참고자료 섹션 포함 필수",
      "pattern": "## 📚 참고자료|\\[참고 문헌|References"
    }
  ]
}